# App
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/ai_support

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# AI (Ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
WHISPER_MODEL=base
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com
IMAP_HOST=imap.gmail.com

# Frontend URL (for generating share links in emails)
FRONTEND_URL=http://localhost:3000

# CRM Webhook Secrets
ZOHO_WEBHOOK_SECRET=
HUBSPOT_WEBHOOK_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Subscription Limits
BASIC_TICKET_LIMIT=500
PRO_TICKET_LIMIT=5000
PREMIUM_TICKET_LIMIT=999999
BASIC_AGENT_LIMIT=3
PRO_AGENT_LIMIT=15
PREMIUM_AGENT_LIMIT=999999
